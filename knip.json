{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": ["src/app/**/*.{ts,tsx}"],
  "project": ["src/**/*.{ts,tsx}"],
  "ignoreDependencies": [
    "tailwindcss",
    "postcss",
    "@fontsource-variable/roboto-flex",
    "@fontsource-variable/roboto-mono"
  ],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  }
}
